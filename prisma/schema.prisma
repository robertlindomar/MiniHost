generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum CloudflareCredentialStatus {
  ACTIVE
  INVALID
  DISABLED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ProjectDatabaseStatus {
  PLANNED
  PROVISIONING
  ACTIVE
  FAILED
  CREATED_MANUALLY
  DISABLED
  ARCHIVED
}

enum PostgresAdminCredentialStatus {
  ACTIVE
  INVALID
  DISABLED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]

  @@map("users")
}

model Domain {
  id        String      @id @default(cuid())
  name      String      @unique
  provider  String      @default("Cloudflare")
  zoneId    String?
  status    String      @default("active")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  records   DnsRecord[]

  @@map("domains")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  status      ProjectStatus @default(DRAFT)
  mainDomain  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  archivedAt  DateTime?
  records     DnsRecord[]
  databases   ProjectDatabase[]

  @@index([status])
  @@map("projects")
}

model ProjectDatabase {
  id                        String                @id @default(cuid())
  projectId                 String
  name                      String
  databaseName              String
  databaseUser              String
  databasePasswordEncrypted String
  host                      String
  port                      Int                   @default(5432)
  status                    ProjectDatabaseStatus @default(PLANNED)
  connectionUrlEncrypted    String
  notes                     String?
  provisionedAt             DateTime?
  provisionedBy             String?
  lastProvisionError        String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  archivedAt                DateTime?
  project                   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([host, databaseName])
  @@unique([host, databaseUser])
  @@index([projectId])
  @@index([status])
  @@map("project_databases")
}

model DnsRecord {
  id                 String    @id @default(cuid())
  domainId           String
  projectId          String?
  type               String
  name               String
  content            String
  ttl                Int?
  proxied            Boolean   @default(false)
  status             String    @default("active")
  comment            String?
  priority           Int?
  cloudflareRecordId String?   @unique
  source             String    @default("manual")
  lastSyncedAt       DateTime?
  deletedAt          DateTime?
  deletedBy          String?
  deletionReason     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  domain             Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([domainId])
  @@index([projectId])
  @@index([source])
  @@index([status])
  @@map("dns_records")
}

model PostgresAdminCredential {
  id                  String                        @id @default(cuid())
  name                String                        @unique @default("default")
  host                String
  port                Int                           @default(5432)
  maintenanceDatabase String                        @default("postgres")
  username            String
  passwordEncrypted   String
  sslEnabled          Boolean                       @default(false)
  status              PostgresAdminCredentialStatus @default(ACTIVE)
  lastTestedAt        DateTime?
  lastTestStatus      String?
  lastTestMessage     String?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  @@map("postgres_admin_credentials")
}

model CloudflareCredential {
  id              String                     @id @default(cuid())
  name            String                     @unique @default("default")
  tokenEncrypted  String
  status          CloudflareCredentialStatus @default(ACTIVE)
  lastTestedAt    DateTime?
  lastTestStatus  String?
  lastTestMessage String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@map("cloudflare_credentials")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  entityName  String?
  userId      String?
  description String
  oldData     Json?
  newData     Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
