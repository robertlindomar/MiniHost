generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum CloudflareCredentialStatus {
  ACTIVE
  INVALID
  DISABLED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ProjectDatabaseStatus {
  PLANNED
  PROVISIONING
  ACTIVE
  FAILED
  CREATED_MANUALLY
  DISABLED
  ARCHIVED
  DESTROYED
  PARTIALLY_DESTROYED
}

enum PostgresAdminCredentialStatus {
  ACTIVE
  INVALID
  DISABLED
}

enum CoolifyCredentialStatus {
  ACTIVE
  INVALID
  DISABLED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]

  @@map("users")
}

model Domain {
  id        String      @id @default(cuid())
  name      String      @unique
  provider  String      @default("Cloudflare")
  zoneId    String?
  status    String      @default("active")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  records   DnsRecord[]

  @@map("domains")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  status      ProjectStatus @default(DRAFT)
  mainDomain  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  archivedAt  DateTime?
  records     DnsRecord[]
  databases   ProjectDatabase[]
  coolifyLink ProjectCoolifyLink?

  @@index([status])
  @@map("projects")
}

model ProjectDatabase {
  id                        String                @id @default(cuid())
  projectId                 String
  name                      String
  databaseName              String
  databaseUser              String
  databasePasswordEncrypted String
  host                      String
  port                      Int                   @default(5432)
  status                    ProjectDatabaseStatus @default(PLANNED)
  connectionUrlEncrypted    String
  notes                     String?
  provisionedAt             DateTime?
  provisionedBy             String?
  lastProvisionError        String?
  disabledAt                DateTime?
  disabledBy                String?
  destroyedAt               DateTime?
  destroyedBy               String?
  lastDestructionError      String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  archivedAt                DateTime?
  project                   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([host, databaseName])
  @@unique([host, databaseUser])
  @@index([projectId])
  @@index([status])
  @@map("project_databases")
}

model DnsRecord {
  id                 String    @id @default(cuid())
  domainId           String
  projectId          String?
  type               String
  name               String
  content            String
  ttl                Int?
  proxied            Boolean   @default(false)
  status             String    @default("active")
  comment            String?
  priority           Int?
  cloudflareRecordId String?   @unique
  source             String    @default("manual")
  lastSyncedAt       DateTime?
  deletedAt          DateTime?
  deletedBy          String?
  deletionReason     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  domain             Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([domainId])
  @@index([projectId])
  @@index([source])
  @@index([status])
  @@map("dns_records")
}

model PostgresAdminCredential {
  id                  String                        @id @default(cuid())
  name                String                        @unique @default("default")
  host                String
  port                Int                           @default(5432)
  maintenanceDatabase String                        @default("postgres")
  username            String
  passwordEncrypted   String
  sslEnabled          Boolean                       @default(false)
  status              PostgresAdminCredentialStatus @default(ACTIVE)
  lastTestedAt        DateTime?
  lastTestStatus      String?
  lastTestMessage     String?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  @@map("postgres_admin_credentials")
}

model CloudflareCredential {
  id              String                     @id @default(cuid())
  name            String                     @unique @default("default")
  tokenEncrypted  String
  status          CloudflareCredentialStatus @default(ACTIVE)
  lastTestedAt    DateTime?
  lastTestStatus  String?
  lastTestMessage String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@map("cloudflare_credentials")
}

model CoolifyCredential {
  id              String                  @id @default(cuid())
  name            String                  @unique @default("default")
  baseUrl         String
  tokenEncrypted  String
  status          CoolifyCredentialStatus @default(ACTIVE)
  lastTestedAt    DateTime?
  lastTestStatus  String?
  lastTestMessage String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@map("coolify_credentials")
}

model CoolifyServer {
  id           String   @id @default(cuid())
  coolifyId    String   @unique
  name         String
  description  String?
  status       String?
  ip           String?
  rawData      Json?
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([status])
  @@map("coolify_servers")
}

model CoolifyProject {
  id           String               @id @default(cuid())
  coolifyId    String               @unique
  name         String
  description  String?
  rawData      Json?
  lastSyncedAt DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  links        ProjectCoolifyLink[]

  @@index([name])
  @@map("coolify_projects")
}

model CoolifyApplication {
  id            String               @id @default(cuid())
  coolifyId     String               @unique
  name          String
  fqdn          String?
  status        String?
  gitRepository String?
  branch        String?
  rawData       Json?
  lastSyncedAt  DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  links         ProjectCoolifyLink[]

  @@index([name])
  @@index([status])
  @@map("coolify_applications")
}

model ProjectCoolifyLink {
  id                        String              @id @default(cuid())
  projectId                 String              @unique
  coolifyProjectCacheId     String?
  coolifyApplicationCacheId String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  project                   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coolifyProject            CoolifyProject?     @relation(fields: [coolifyProjectCacheId], references: [id], onDelete: SetNull)
  coolifyApplication        CoolifyApplication? @relation(fields: [coolifyApplicationCacheId], references: [id], onDelete: SetNull)

  @@index([coolifyProjectCacheId])
  @@index([coolifyApplicationCacheId])
  @@map("project_coolify_links")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  entityName  String?
  userId      String?
  description String
  oldData     Json?
  newData     Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
